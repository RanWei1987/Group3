// ======================================================
// nextflow.config
// ======================================================

docker {
    enabled      = true
    fixOwnership = true
}

workDir = './work'

// ======================================================
// PROCESS DEFAULTS
// ======================================================

process {
    executor     = 'local'
    cpus         = 2
    memory       = '4 GB'
    errorStrategy = 'retry'
    maxRetries   = 1

    // ---- Containers ----
    withName: 'EL_GATO_FASTQ|EL_GATO_FASTA|EL_GATO_ONT' {
        container = 'staphb/elgato:1.22.0'
    }
    withName: SUBSAMPLE_ONT {
        container = 'staphb/seqtk:latest'
    }
    withName: RAVEN {
        container = 'staphb/raven:latest'
    }
    withName: MEDAKA {
        container = 'staphb/medaka:latest'
    }
    withName: NANOPLOT {
        container = 'staphb/nanoplot:latest'
    }
    withName: PROKKA {
        container = 'staphb/prokka:latest'
    }
    withName: CHECKM2 {
        container        = 'staphb/checkm2:latest'
        // Mount the CheckM2 database — edit the host path to match your system
        containerOptions = "-v ${projectDir}/module_db/CheckM2_database:/mnt/checkm2_db:ro"
    }
    withName: AMRFINDER {
        container        = 'staphb/ncbi-amrfinderplus:latest'
        // Mount a local AMRFinder database to avoid downloading at runtime
        // Remove containerOptions if you want AMRFinder to use its bundled db
        containerOptions = "-v ${projectDir}/amrfinder_db:/usr/local/share/amrfinderdb:ro"
    }
}

// ======================================================
// PROFILES  (select with -profile docker or -profile local)
// ======================================================

profiles {
    docker {
        docker.enabled   = true
        process.executor = 'local'
    }
    local {
        docker.enabled   = false
        process.executor = 'local'
    }
}
